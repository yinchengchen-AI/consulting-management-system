# ============================================
# 咨询公司业务管理系统 - 环境变量配置
# ============================================
# 说明: 复制此文件为 .env 并根据需要修改配置
# 命令: cp .env.example .env
# ============================================

# ============================================
# 应用配置
# ============================================
APP_NAME=ConsultingSystem
APP_ENV=development
APP_VERSION=1.0.0
APP_PORT=8080

# ============================================
# 数据库配置 (PostgreSQL)
# ============================================
# 主机名（Docker 中使用服务名）
DB_HOST=postgres
# 端口
DB_PORT=5432
# 用户名
DB_USER=consulting_user
# 密码（生产环境请使用强密码）
DB_PASSWORD=consulting_pass
# 数据库名
DB_NAME=consulting_system
# SSL 模式 (disable/require/verify-ca/verify-full)
DB_SSL_MODE=disable
# 最大打开连接数
DB_MAX_OPEN_CONNS=25
# 最大空闲连接数
DB_MAX_IDLE_CONNS=5
# 连接最大生命周期
DB_CONN_MAX_LIFETIME=5m

# ============================================
# Redis 配置
# ============================================
# 主机名（Docker 中使用服务名）
REDIS_HOST=redis
# 端口
REDIS_PORT=6379
# 密码（留空表示无密码）
REDIS_PASSWORD=
# 数据库索引 (0-15)
REDIS_DB=0
# 连接池大小
REDIS_POOL_SIZE=10

# ============================================
# JWT 配置
# ============================================
# JWT 密钥（生产环境请使用强密钥，至少 32 位）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# Token 过期时间（小时）
JWT_EXPIRE_HOURS=24
# 刷新 Token 过期时间（小时）
JWT_REFRESH_HOURS=168

# ============================================
# 日志配置
# ============================================
# 日志级别 (debug/info/warn/error)
LOG_LEVEL=debug
# 日志格式 (json/text)
LOG_FORMAT=json
# 日志输出 (stdout/file)
LOG_OUTPUT=stdout

# ============================================
# CORS 配置
# ============================================
# 允许的源（逗号分隔）
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost,http://localhost:80
# 允许的 HTTP 方法
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
# 允许的请求头
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID

# ============================================
# 文件上传配置
# ============================================
# 最大文件大小（字节，默认 10MB）
UPLOAD_MAX_SIZE=10485760
# 允许的文件类型（逗号分隔）
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
# 文件存储路径
UPLOAD_STORAGE_PATH=./uploads

# ============================================
# 邮件配置 (可选，用于发送通知)
# ============================================
# SMTP 服务器地址
SMTP_HOST=
# SMTP 端口
SMTP_PORT=587
# SMTP 用户名
SMTP_USER=
# SMTP 密码
SMTP_PASSWORD=
# 发件人地址
SMTP_FROM=

# ============================================
# 前端配置
# ============================================
# API 基础 URL
VITE_API_BASE_URL=http://localhost:8080/api/v1
# 应用标题
VITE_APP_TITLE=咨询公司业务管理系统
# 应用版本
VITE_APP_VERSION=1.0.0

# ============================================
# 前端端口配置 (Docker)
# ============================================
FRONTEND_PORT=80
FRONTEND_HTTPS_PORT=443
