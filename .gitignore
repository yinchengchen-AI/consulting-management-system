# ============================================
# 咨询公司业务管理系统 - Git 忽略配置
# ============================================

# ============================================
# 环境配置文件
# ============================================
.env
.env.local
.env.*.local

# ============================================
# 依赖目录
# ============================================
# Go
backend/vendor/

# Node.js
frontend/node_modules/
frontend/.pnpm-store/
frontend/dist/
frontend/dist-ssr/

# ============================================
# 构建产物
# ============================================
backend/bin/
backend/*.exe
backend/*.exe~
backend/*.dll
backend/*.so
backend/*.dylib
backend/main

# ============================================
# 测试文件
# ============================================
*.test
*.out
coverage.html
coverage.out

# ============================================
# IDE 和编辑器
# ============================================
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#

# ============================================
# 操作系统文件
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# Linux
*~
.nfs*

# ============================================
# 日志文件
# ============================================
*.log
logs/
backend/logs/

# ============================================
# 数据目录
# ============================================
data/
backups/

# ============================================
# 上传文件
# ============================================
backend/uploads/*
!backend/uploads/.gitkeep

# ============================================
# SSL 证书
# ============================================
docker/nginx/ssl/*.pem
docker/nginx/ssl/*.key
docker/nginx/ssl/*.crt

# ============================================
# 临时文件
# ============================================
tmp/
temp/
*.tmp
*.temp

# ============================================
# 其他
# ============================================
*.pid
*.seed
*.pid.lock
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ============================================
# Docker
# ============================================
.dockerignore

# ============================================
# 本地开发
# ============================================
*.local
